SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=...
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM
STABLE_DIFFUSION_API_KEY=...
YOUTUBE_API_KEY=...
FRONTEND_ORIGIN=http://localhost:5173

# Image generation: "dalle3" (default, uses OPENAI_API_KEY) | "stabilityai"
IMAGE_PROVIDER=dalle3

# Video generation (optional — Step 5 skips video if neither is set)
RUNWAY_API_KEY=
SVD_SERVER_URL=

# Supabase Storage bucket name (must be created manually and set to public)
SUPABASE_STORAGE_BUCKET=project-assets

# YouTube OAuth2 upload (Step 8)
# 1. Create OAuth2 Desktop app credentials in Google Cloud Console
# 2. Download client_secrets.json and paste its entire content (minified) here
YOUTUBE_CLIENT_SECRETS_JSON={"installed":{"client_id":"...","client_secret":"...","redirect_uris":["http://localhost"],"auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}}
# 3. Visit GET /auth/youtube in your browser to run the OAuth2 flow
# 4. Paste the returned token_json value here
YOUTUBE_OAUTH_TOKEN_JSON=
# 5. Redirect URI must match exactly what is in Google Cloud Console
YOUTUBE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/youtube/callback
